@page
@model PonyUpPerformance.Web.Pages.BuyAnalyzerModel

@{
    ViewData["Title"] = "Buy Analyzer";

    string stoplightImage = "/images/ponyup-stoplight-off.png";
    string stoplightClass = "off";
    string recommendation = "READY";
    string scoreText = "---";
    string reasoning = "Enter the vehicle information and run the analysis.";

    if (Model.Result != null)
    {
        stoplightClass =
            Model.Result.ConfidenceScore >= 75 ? "green" :
            Model.Result.ConfidenceScore >= 50 ? "yellow" :
            "red";

        stoplightImage =
            Model.Result.ConfidenceScore >= 75 ? "/images/ponyup-stoplight-green.png" :
            Model.Result.ConfidenceScore >= 50 ? "/images/ponyup-stoplight-yellow.png" :
            "/images/ponyup-stoplight-red.png";

        recommendation = Model.Result.Recommendation;
        scoreText = Model.Result.ConfidenceScore + "%";
        reasoning = Model.Result.Reasoning;
    }
}

<section class="page-section analyzer-page buy-bg">
    <h1 class="section-title">BUY ANALYZER</h1>
    <p class="section-subtitle">Should you buy this vehicle, negotiate harder, or walk away?</p>

    <div class="price-card" style="max-width:900px;margin:0 auto;">
        <form method="post">
            <label>Year</label>
            <input asp-for="Input.Year" />

            <label>Make</label>
            <input asp-for="Input.Make" />

            <label>Model</label>
            <input asp-for="Input.Model" />

            <label>Mileage</label>
            <input asp-for="Input.Mileage" />

            <label>Asking Price</label>
            <input asp-for="Input.AskingPrice" />

            <label>Estimated Repair Cost</label>
            <input asp-for="Input.EstimatedRepairCost" />

            <label>Market Value</label>
            <input asp-for="Input.MarketValue" />

            <button class="btn-red" type="submit" style="margin-top:20px;">
                ANALYZE BUY
            </button>
        </form>
    </div>

    <div class="ponyup-result-panel @stoplightClass">
        <div>
            <img src="@stoplightImage" class="ponyup-stoplight-img" alt="PonyUp Stoplight" />
        </div>

        <div class="ponyup-result-copy">
            <p>@(Model.Result == null ? "ANALYSIS STATUS" : "ANALYSIS COMPLETE")</p>
            <h2>@recommendation</h2>
            <strong>@scoreText</strong>
            <p>@reasoning</p>
        </div>
    </div>
</section>
