@page
@model PonyUpPerformance.Web.Pages.SellAnalyzerModel

@{
    ViewData["Title"] = "Sell Analyzer";
}

<section class="page-section">
    <h1 class="section-title">SELL ANALYZER</h1>
    <p class="section-subtitle">Should you sell now, repair first, or hold?</p>

    <div class="price-card" style="max-width:900px;margin:0 auto;">
        <form method="post">
            <label>Year</label>
            <input asp-for="Input.Year" />

            <label>Make</label>
            <input asp-for="Input.Make" />

            <label>Model</label>
            <input asp-for="Input.Model" />

            <label>Mileage</label>
            <input asp-for="Input.Mileage" />

            <label>Current Offer / Expected Sale Price</label>
            <input asp-for="Input.ExpectedSalePrice" />

            <label>Estimated Repair Cost Before Selling</label>
            <input asp-for="Input.EstimatedRepairCost" />

            <label>Market Value</label>
            <input asp-for="Input.MarketValue" />

            <button class="btn-red" type="submit" style="margin-top:20px;">
                ANALYZE SELL
            </button>
        </form>
    </div>

    @if (Model.Result != null)
    {
        <div class="price-card featured" style="max-width:900px;margin:30px auto 0;">
            <h2>@Model.Result.Recommendation</h2>
<strong>@Model.Result.ConfidenceScore / 100</strong>
<p>@Model.Result.Reasoning</p>
    }
</section>
