@page
@model IndexModel

@{
    ViewData["Title"] = "Home";
}

<section class="ponyup-hero">
    <div class="hero-overlay">
        <div class="hero-content">

            <img src="~/images/ponyup-wordlogo.png"
                 alt="PonyUp Performance"
                 class="hero-word-logo" />

            <h1 class="hero-main-slogan">
                ALL CARS. ALL BUILDS. ALL BUSINESS.
            </h1>

            <h2 class="hero-sub-slogan">
                Know Before You Spend.
            </h2>

            <p class="hero-support-text">
                Repair it. Buy it. Sell it. Trade it. Upgrade it.
                PonyUp helps you decide if the money makes sense before you spend it.
            </p>

            <div class="hero-buttons">
                <a class="btn btn-danger btn-lg" href="/Repair">Start Free Analysis</a>
                <a class="btn btn-outline-light btn-lg" href="#pricing">See Pricing</a>
                <a class="btn btn-outline-light btn-lg" href="#resources">Explore Resources</a>
            </div>

        </div>
    </div>
</section>

<section class="decision-section py-5">
    <div class="container text-center">

        <h2 class="section-title">What Are You Trying To Decide?</h2>
        <p class="section-subtitle">
            Choose the money decision in front of you.
        </p>

        <div class="row g-4 mt-4">

            <div class="col-md">
                <a class="decision-card" href="/Repair">
                    <h3>Repair</h3>
                    <p>Should you fix it or walk away?</p>
                </a>
            </div>

            <div class="col-md">
                <a class="decision-card" href="/Buy">
                    <h3>Buy</h3>
                    <p>Is the vehicle worth the asking price?</p>
                </a>
            </div>

            <div class="col-md">
                <a class="decision-card" href="/Sell">
                    <h3>Sell</h3>
                    <p>Should you sell now or hold it?</p>
                </a>
            </div>

            <div class="col-md">
                <a class="decision-card" href="/Trade">
                    <h3>Trade</h3>
                    <p>Does the trade make financial sense?</p>
                </a>
            </div>

            <div class="col-md">
                <a class="decision-card" href="/Upgrade">
                    <h3>Upgrade</h3>
                    <p>Is the upgrade worth the money?</p>
                </a>
            </div>

        </div>
    </div>
</section>

<section id="pricing" class="ponyup-pricing-preview py-5">
    <div class="container">

        <div class="text-center mb-5">
            <h2 class="section-title">Pricing</h2>
            <p class="section-subtitle">
                Start free. Upgrade only when PonyUp proves useful.
            </p>
        </div>

        <div class="row g-4">

            <div class="col-md-3">
                <a href="/Repair"
                   class="pricing-card pricing-home-card text-decoration-none">
                    <h4>FREE</h4>
                    <p>1 Full Analysis</p>
                    <strong>$0</strong>
                    <span class="btn btn-outline-light mt-3">Start Free</span>
                </a>
            </div>

            <div class="col-md-3">
                <form method="post" action="/Checkout" class="h-100">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="plan" value="quick" />

                    <button type="submit"
                            class="pricing-card pricing-home-card pricing-button-card featured">
                        <h4>QUICK PACK</h4>
                        <p>5 Analyses</p>
                        <strong>$5.99</strong>
                        <span class="btn btn-danger mt-3">Buy Quick Pack</span>
                    </button>
                </form>
            </div>

            <div class="col-md-3">
                <form method="post" action="/Checkout" class="h-100">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="plan" value="pro" />

                    <button type="submit"
                            class="pricing-card pricing-home-card pricing-button-card">
                        <h4>PRO</h4>
                        <p>10 Analyses / Month</p>
                        <strong>$9.99/mo</strong>
                        <span class="btn btn-outline-light mt-3">Subscribe</span>
                    </button>
                </form>
            </div>

            <div class="col-md-3">
                <form method="post" action="/Checkout" class="h-100">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="plan" value="unlimited" />

                    <button type="submit"
                            class="pricing-card pricing-home-card pricing-button-card">
                        <h4>UNLIMITED</h4>
                        <p>Unlimited Analyses</p>
                        <strong>$19.99/mo</strong>
                        <span class="btn btn-outline-light mt-3">Go Unlimited</span>
                    </button>
                </form>
            </div>

        </div>
    </div>
</section>

<section id="resources" class="resources-section py-5">
    <div class="container text-center">

        <h2 class="section-title">Resources</h2>
        <p class="section-subtitle">
            Useful links for parts, valuation, performance upgrades, and shop searches.
        </p>

        <div class="row g-4 mt-4">

            <div class="col-md-3">
                <a class="resource-card" href="https://www.rockauto.com/" target="_blank">
                    RockAuto
                </a>
            </div>

            <div class="col-md-3">
                <a class="resource-card" href="https://www.autozone.com/" target="_blank">
                    AutoZone
                </a>
            </div>

            <div class="col-md-3">
                <a class="resource-card" href="https://www.oreillyauto.com/" target="_blank">
                    O'Reilly
                </a>
            </div>

            <div class="col-md-3">
                <a class="resource-card" href="https://www.napaonline.com/" target="_blank">
                    NAPA
                </a>
            </div>

            <div class="col-md-3">
                <a class="resource-card" href="https://shop.advanceautoparts.com/" target="_blank">
                    Advance Auto
                </a>
            </div>

            <div class="col-md-3">
                <a class="resource-card" href="https://www.roughcountry.com/" target="_blank">
                    Rough Country
                </a>
            </div>

            <div class="col-md-3">
                <a class="resource-card" href="https://zzperformance.com/" target="_blank">
                    ZZPerformance
                </a>
            </div>

            <div class="col-md-3">
                <a class="resource-card" href="https://www.kbb.com/" target="_blank">
                    Kelley Blue Book
                </a>
            </div>

        </div>

        <p class="resource-disclaimer mt-4">
            Resource links are provided for convenience. PonyUp Performance is not affiliated with these companies unless specifically stated.
        </p>

    </div>
</section>
