@page
@model PonyUpPerformance.Web.Pages.TradeAnalyzerModel

@{
    ViewData["Title"] = "Trade Analyzer";

    string stoplightImage = "/images/ponyup-stoplight-off.png";
    string stoplightClass = "off";
    string recommendation = "READY";
    string scoreText = "---";
    string reasoning = "Enter both vehicles and run the trade analysis.";

    if (Model.Result != null)
    {
        stoplightClass =
            Model.Result.ConfidenceScore >= 75 ? "green" :
            Model.Result.ConfidenceScore >= 50 ? "yellow" :
            "red";

        stoplightImage =
            Model.Result.ConfidenceScore >= 75 ? "/images/ponyup-stoplight-green.png" :
            Model.Result.ConfidenceScore >= 50 ? "/images/ponyup-stoplight-yellow.png" :
            "/images/ponyup-stoplight-red.png";

        recommendation = Model.Result.Recommendation;
        scoreText = Model.Result.ConfidenceScore + "%";
        reasoning = Model.Result.Reasoning;
    }
}

<section class="page-section analyzer-page trade-bg">
    <h1 class="section-title">TRADE ANALYZER</h1>
    <p class="section-subtitle">Is this trade actually worth making?</p>

    <div class="price-card" style="max-width:1000px;margin:0 auto;">
        <form method="post">
            <h3>YOUR VEHICLE</h3>

            <label>Year</label>
            <input asp-for="Input.YourYear" />

            <label>Make</label>
            <input asp-for="Input.YourMake" />

            <label>Model</label>
            <input asp-for="Input.YourModel" />

            <label>Mileage</label>
            <input asp-for="Input.YourMileage" />

            <label>Estimated Value</label>
            <input asp-for="Input.YourValue" />

            <hr />

            <h3>THEIR VEHICLE</h3>

            <label>Year</label>
            <input asp-for="Input.TheirYear" />

            <label>Make</label>
            <input asp-for="Input.TheirMake" />

            <label>Model</label>
            <input asp-for="Input.TheirModel" />

            <label>Mileage</label>
            <input asp-for="Input.TheirMileage" />

            <label>Estimated Value</label>
            <input asp-for="Input.TheirValue" />

            <label>Estimated Repairs Needed</label>
            <input asp-for="Input.EstimatedRepairCost" />

            <button class="btn-red" type="submit" style="margin-top:25px;">
                ANALYZE TRADE
            </button>
        </form>
    </div>

    <div class="ponyup-result-panel @stoplightClass">
        <div>
            <img src="@stoplightImage" class="ponyup-stoplight-img" alt="PonyUp Stoplight" />
        </div>

        <div class="ponyup-result-copy">
            <p>@(Model.Result == null ? "ANALYSIS STATUS" : "ANALYSIS COMPLETE")</p>
            <h2>@recommendation</h2>
            <strong>@scoreText</strong>
            <p>@reasoning</p>
        </div>
    </div>
</section>
