<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PonyUp Performance</title>

    <link rel="icon" type="image/jpeg" href="~/images/ponyup-logo.jpg" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PonyUpPerformance.Web.styles.css" asp-append-version="true" />
</head>

<body>
    <header class="ponyup-header">
        <nav class="ponyup-navbar">
            <a class="ponyup-brand" asp-page="/Index">
                <img src="~/images/ponyup-logo.jpg" alt="PonyUp Performance" />
            </a>

            <div class="ponyup-nav-links">
                <a asp-page="/Index">Home</a>
                <a asp-page="/DecisionCenter">Decision Center</a>
                <a asp-page="/RepairAnalyzer">Repair</a>
                <a asp-page="/Buy">Buy</a>
                <a asp-page="/Sell">Sell</a>
                <a asp-page="/Trade">Trade</a>
                <a asp-page="/Upgrade">Upgrade</a>
                <a asp-page="/Resources">Resources</a>
                <a class="pricing-nav" asp-page="/Pricing">Pricing</a>
                <a asp-page="/MyGarage">Garage</a>
                <a asp-area="Identity" asp-page="/Account/Register">Register</a>
                <a asp-area="Identity" asp-page="/Account/Login">Login</a>
            </div>
        </nav>
    </header>

    <main>
        @RenderBody()
    </main>

    <footer class="ponyup-footer">
        <img src="~/images/ponyup-logo.jpg" alt="PonyUp Performance" />
        <p>© 2026 PonyUp Performance. Vehicle decisions made smarter.</p>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
