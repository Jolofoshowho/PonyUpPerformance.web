<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PonyUp Performance</title>

    <link rel="icon" type="image/jpeg" href="~/images/ponyup-logo.jpg" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PonyUpPerformance.Web.styles.css" asp-append-version="true" />
</head>

<body>
    <header class="ponyup-header">
        <nav class="ponyup-navbar">

            <a class="ponyup-brand" asp-page="/Index">
                <img src="~/images/ponyup-logo.jpg" alt="PonyUp Performance" />
            </a>

            <div class="ponyup-nav-links">
    <a asp-page="/Index">HOME</a>
    <a asp-page="/DecisionCenter">DECISION CENTER</a>
    <a asp-page="/RepairAnalyzer">REPAIR</a>
    <a asp-page="/BuyAnalyzer">BUY</a>
    <a asp-page="/SellAnalyzer">SELL</a>
    <a asp-page="/TradeAnalyzer">TRADE</a>
    <a asp-page="/UpgradeAnalyzer">UPGRADE</a>
    <a asp-page="/Resources">RESOURCES</a>
    <a class="pricing-nav" asp-page="/Pricing">PRICING</a>
    <a asp-page="/MyGarage">GARAGE</a>

    @if (User.Identity?.IsAuthenticated ?? false)
    {
        <form asp-area="Identity"
              asp-page="/Account/Logout"
              asp-route-returnUrl="@Url.Page("/Index")"
              method="post"
              style="display:inline;">
            <button type="submit" class="ponyup-auth-button">LOGOUT</button>
        </form>
    }
    else
    {
        <a class="ponyup-auth-link"
           asp-area="Identity"
           asp-page="/Account/Register">REGISTER</a>

        <a class="ponyup-auth-button"
           asp-area="Identity"
           asp-page="/Account/Login">LOGIN</a>
    }
</div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="ponyup-footer">
        <img src="~/images/ponyup-logo.jpg" alt="PonyUp Performance" />
        <p>© 2026 PonyUp Performance. Vehicle decisions made smarter.</p>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
