@page
@model PonyUpPerformance.Web.Pages.UpgradeAnalyzerModel

@{
    ViewData["Title"] = "Upgrade Analyzer";

    string stoplightImage = "/images/ponyup-stoplight-off.png";
    string stoplightClass = "off";
    string recommendation = "READY";
    string scoreText = "---";
    string reasoning = "Enter the upgrade details and run the analysis.";

    if (Model.Result != null)
    {
        stoplightClass =
            Model.Result.ConfidenceScore >= 75 ? "green" :
            Model.Result.ConfidenceScore >= 50 ? "yellow" :
            "red";

        stoplightImage =
            Model.Result.ConfidenceScore >= 75 ? "/images/ponyup-stoplight-green.png" :
            Model.Result.ConfidenceScore >= 50 ? "/images/ponyup-stoplight-yellow.png" :
            "/images/ponyup-stoplight-red.png";

        recommendation = Model.Result.Recommendation;
        scoreText = Model.Result.ConfidenceScore + "%";
        reasoning = Model.Result.Reasoning;
    }
}

<section class="page-section analyzer-page upgrade-bg">
    <h1 class="section-title">UPGRADE ANALYZER</h1>
    <p class="section-subtitle">Should you spend money upgrading this vehicle?</p>

    <div class="price-card" style="max-width:1000px;margin:0 auto;">
        <form method="post">
            <label>Year</label>
            <input asp-for="Input.Year" />

            <label>Make</label>
            <input asp-for="Input.Make" />

            <label>Model</label>
            <input asp-for="Input.Model" />

            <label>Current Vehicle Value</label>
            <input asp-for="Input.CurrentValue" />

            <label>Upgrade Cost</label>
            <input asp-for="Input.UpgradeCost" />

            <label>Estimated Value Added</label>
            <input asp-for="Input.ValueAdded" />

            <label>Estimated Horsepower Gain</label>
            <input asp-for="Input.HorsepowerGain" />

            <label>Reliability Impact (-100 to +100)</label>
            <input asp-for="Input.ReliabilityImpact" />

            <button class="btn-red" type="submit" style="margin-top:25px;">
                ANALYZE UPGRADE
            </button>
        </form>
    </div>

    <div class="ponyup-result-panel @stoplightClass">
        <div>
            <img src="@stoplightImage" class="ponyup-stoplight-img" alt="PonyUp Stoplight" />
        </div>

        <div class="ponyup-result-copy">
            <p>@(Model.Result == null ? "ANALYSIS STATUS" : "ANALYSIS COMPLETE")</p>
            <h2>@recommendation</h2>
            <strong>@scoreText</strong>
            <p>@reasoning</p>
        </div>
    </div>
</section>
