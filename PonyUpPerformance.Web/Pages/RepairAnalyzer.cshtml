@page
@model PonyUpPerformance.Web.Pages.RepairAnalyzerModel

@{
    ViewData["Title"] = "Repair Analyzer";

    int decisionScore = Model.Result?.Score ?? 0;
    int confidenceScore = Model.Result?.ConfidenceScore ?? 0;

    string recommendation =
        Model.Result?.Recommendation
        ?? "READY";

    string reasoning =
        Model.Result?.Reasoning
        ?? "Enter the repair details and run the analysis.";

    var stoplight =
        new PonyUpPerformance.Web.Models.PonyUpStoplightResultViewModel
        {
            HasResult = Model.Result != null,
            AnalysisType = "REPAIR DECISION",
            Recommendation = recommendation,
            ConfidenceScore = decisionScore,
            Reasoning = reasoning
        };
}

<section class="page-section analyzer-page repair-bg">
    <h1 class="section-title">REPAIR ANALYZER</h1>

    <p class="section-subtitle">
        Know before you spend. Determine whether repairing this vehicle makes financial sense.
    </p>

    @if (!string.IsNullOrWhiteSpace(Model.CreditMessage))
    {
        <div class="price-card featured"
             style="max-width:900px;margin:0 auto 24px;">
            <p>@Model.CreditMessage</p>
        </div>
    }

    <div class="price-card analyzer-card"
         style="max-width:900px;margin:0 auto;">

        <form method="post" class="analyzer-form">
            <input asp-for="EstimateCreditConsumed" type="hidden" />

            <div class="form-row">
                <label asp-for="Input.VehicleYear">Year</label>
                <input asp-for="Input.VehicleYear" />
            </div>

            <div class="form-row">
                <label asp-for="Input.VehicleMake">Make</label>
                <input asp-for="Input.VehicleMake" />
            </div>

            <div class="form-row">
                <label asp-for="Input.VehicleModel">Model</label>
                <input asp-for="Input.VehicleModel" />
            </div>

            <div class="form-row">
                <label asp-for="EstimateInput.City">City</label>
                <input asp-for="EstimateInput.City" />
            </div>

            <div class="form-row">
                <label asp-for="EstimateInput.State">State</label>
                <input asp-for="EstimateInput.State" />
            </div>

            <div class="form-row">
                <label asp-for="EstimateInput.ZipCode">ZIP Code</label>
                <input asp-for="EstimateInput.ZipCode" />
            </div>

            <div class="form-row">
                <label asp-for="EstimateInput.RepairType">Repair Type</label>

                <select asp-for="EstimateInput.RepairType">
                    @foreach (string repairType in Model.RepairTypes)
                    {
                        <option value="@repairType">
                            @repairType
                        </option>
                    }
                </select>
            </div>

            <div class="form-check-row">
                <label>
                    <input asp-for="EstimateInput.IncludeDiagnosticFee" />
                    Include Diagnostic Fee
                </label>

                <label>
                    <input asp-for="EstimateInput.IncludeTowFee" />
                    Include Tow Fee
                </label>
            </div>

            <div class="form-actions">
                <button class="btn-red"
                        type="submit"
                        asp-page-handler="Estimate"
                        onclick="return confirm('Does all of the information look correct? Estimating the repair cost will use one analysis credit.');">
                    ESTIMATE REPAIR COST
                </button>
            </div>

            @if (Model.EstimateResult != null)
            {
                <div class="price-card featured estimate-result-card">
                    <h2>REPAIR COST ESTIMATE</h2>

                    <p>
                        <strong>Repair:</strong>
                        @Model.EstimateResult.RepairType
                    </p>

                    <p>
                        <strong>Location:</strong>
                        @Model.EstimateResult.LocationUsed
                    </p>

                    <p>
                        <strong>Low Estimate:</strong>
                        @Model.EstimateResult.LowEstimate.ToString("C")
                    </p>

                    <p>
                        <strong>Expected Estimate:</strong>
                        @Model.EstimateResult.ExpectedEstimate.ToString("C")
                    </p>

                    <p>
                        <strong>High Estimate:</strong>
                        @Model.EstimateResult.HighEstimate.ToString("C")
                    </p>

                    <p>
                        <strong>Average Labor Rate:</strong>
                        @Model.EstimateResult.LaborRateAverage.ToString("C")
                        per hour
                    </p>

                    <p>
                        <strong>Average Labor Time:</strong>
                        @Model.EstimateResult.LaborHoursAverage hours
                    </p>

                    <p>
                        <strong>Average Parts Cost:</strong>
                        @Model.EstimateResult.PartsAverage.ToString("C")
                    </p>

                    <p>
                        <strong>Average Shop Fee:</strong>
                        @Model.EstimateResult.ShopFeeAverage.ToString("C")
                    </p>

                    @if (Model.EstimateResult.DiagnosticFee > 0)
                    {
                        <p>
                            <strong>Diagnostic Fee:</strong>
                            @Model.EstimateResult.DiagnosticFee.ToString("C")
                        </p>
                    }

                    @if (Model.EstimateResult.TowFee > 0)
                    {
                        <p>
                            <strong>Tow Fee:</strong>
                            @Model.EstimateResult.TowFee.ToString("C")
                        </p>
                    }

                    <p>
                        @Model.EstimateResult.EstimateNote
                    </p>
                </div>
            }

            <div class="analyzer-section-divider"></div>

            <div class="form-row">
                <label asp-for="Input.RepairCost">Repair Cost</label>
                <input asp-for="Input.RepairCost" />
            </div>

            <div class="form-row">
                <label asp-for="Input.Mileage">Mileage</label>
                <input asp-for="Input.Mileage" />
            </div>

            <div class="form-row">
                <label asp-for="Input.VehicleValue">
                    Estimated Vehicle Value
                </label>
                <input asp-for="Input.VehicleValue" />
            </div>

            <div class="form-row">
                <label asp-for="Input.Condition">
                    Overall Vehicle Condition
                </label>

                <select asp-for="Input.Condition">
                    <option value="Poor">Poor</option>
                    <option value="Fair">Fair</option>
                    <option value="Good">Good</option>
                    <option value="Excellent">Excellent</option>
                </select>
            </div>

            <div class="form-row">
                <label asp-for="Input.OwnershipYears">
                    Years You Plan to Keep It
                </label>
                <input asp-for="Input.OwnershipYears" />
            </div>

            <div class="form-check-row single-check">
                <label>
                    <input asp-for="Input.IsSafetyCritical" />
                    Safety-Critical Repair
                </label>
            </div>

            <div class="form-actions">
    <button class="btn-red"
            type="submit"
            asp-page-handler="Analyze">
        ANALYZE REPAIR
    </button>
</div>

</form>
</div>

    @if (Model.Result != null)
    {
        <div class="price-card featured"
             style="max-width:900px;margin:24px auto 0;">

            <h2>REPAIR ANALYSIS</h2>

            <p>
                <strong>Decision Score:</strong>
                @Model.Result.Score / 100
            </p>

            <p>
                <strong>Confidence Score:</strong>
                @Model.Result.ConfidenceScore / 100
            </p>

            <p>
                <strong>Recommendation:</strong>
                @Model.Result.Recommendation
            </p>

            <p>
                <strong>Risk Level:</strong>
                @Model.Result.RiskLevel
            </p>

            <p>
                <strong>Financial Impact:</strong>
                @Model.Result.FinancialImpact
            </p>

            <div class="analyzer-section-divider"></div>

            <h3>WHY WE RECOMMEND THIS</h3>

            <p>@Model.Result.Reasoning</p>

            @if (Model.Result.NextSteps.Count > 0)
            {
                <h3>NEXT STEPS</h3>

                <ul>
                    @foreach (string nextStep in Model.Result.NextSteps)
                    {
                        <li>@nextStep</li>
                    }
                </ul>
            }
        </div>
    }

    <partial name="_PonyUpStoplightResult"
             model="stoplight" />
</section>
