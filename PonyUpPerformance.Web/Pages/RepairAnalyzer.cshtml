@page
@model PonyUpPerformance.Web.Pages.RepairAnalyzerModel

@{
    ViewData["Title"] = "Repair Analyzer";

    int confidence = 0;
    string recommendation = "READY";
    string reasoning = "Enter the repair details and run the analysis.";

    if (Model.Result != null)
    {
        var resultType = Model.Result.GetType();

        var scoreProp =
            resultType.GetProperty("ConfidenceScore") ??
            resultType.GetProperty("Score");

        var recommendationProp =
            resultType.GetProperty("Recommendation") ??
            resultType.GetProperty("Decision");

        var reasoningProp =
            resultType.GetProperty("Reasoning") ??
            resultType.GetProperty("Summary");

        confidence = scoreProp != null ? Convert.ToInt32(scoreProp.GetValue(Model.Result)) : 0;
        recommendation = recommendationProp?.GetValue(Model.Result)?.ToString() ?? "ANALYSIS COMPLETE";
        reasoning = reasoningProp?.GetValue(Model.Result)?.ToString() ?? "Repair analysis complete.";
    }

    var stoplight = new PonyUpPerformance.Web.Models.PonyUpStoplightResultViewModel
    {
        HasResult = Model.Result != null,
        AnalysisType = "ANALYSIS STATUS",
        Recommendation = recommendation,
        ConfidenceScore = confidence,
        Reasoning = reasoning
    };
}

<section class="page-section analyzer-page repair-bg">
    <h1 class="section-title">REPAIR ANALYZER</h1>
    <p class="section-subtitle">Should you repair it, price it differently, or walk away?</p>

    @if (!string.IsNullOrWhiteSpace(Model.CreditMessage))
    {
        <div class="price-card featured" style="max-width:900px;margin:0 auto 24px;">
            <p>@Model.CreditMessage</p>
        </div>
    }

    <div class="price-card" style="max-width:900px;margin:0 auto;">
        <form method="post">
            <label>Year</label>
            <input asp-for="Input.VehicleYear" />

            <label>Make</label>
            <input asp-for="Input.VehicleMake" />

            <label>Model</label>
            <input asp-for="Input.VehicleModel" />

            <label>Repair Cost</label>
            <input asp-for="Input.RepairCost" />

            <button class="btn-red" type="submit" style="margin-top:20px;">
                ANALYZE REPAIR
            </button>
        </form>
    </div>

    <partial name="_PonyUpStoplightResult" model="stoplight" />
</section>
