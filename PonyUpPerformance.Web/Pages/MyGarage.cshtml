@page
@model PonyUpPerformance.Web.Pages.MyGarageModel

@{
    ViewData["Title"] = "My Garage";
}

<section class="page-section">
    <h1 class="section-title">MY GARAGE</h1>
    <p class="section-subtitle">
        Full vehicle garage, paint selector, analysis history, and quick actions are coming soon.
    </p>

    <div class="price-card featured" style="max-width:1000px;margin:0 auto;text-align:center;">
        <h2>GARAGE COMING SOON</h2>

        <p>
            This section will let users save vehicles, view past analyses, track repair decisions,
            and manage their personal PonyUp vehicle profile.
        </p>

        <p style="margin-top:20px;">
            For now, use the analyzers from the navigation bar:
        </p>

        <div class="hero-buttons" style="justify-content:center;flex-wrap:wrap;margin-top:20px;">
            <a class="btn-red" asp-page="/RepairAnalyzer">Repair</a>
            <a class="btn-red" asp-page="/BuyAnalyzer">Buy</a>
            <a class="btn-red" asp-page="/SellAnalyzer">Sell</a>
            <a class="btn-red" asp-page="/TradeAnalyzer">Trade</a>
            <a class="btn-red" asp-page="/UpgradeAnalyzer">Upgrade</a>
        </div>
    </div>
</section>
