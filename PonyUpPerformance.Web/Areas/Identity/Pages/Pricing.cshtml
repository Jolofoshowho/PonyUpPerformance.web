@page
@model PonyUpPerformance.Web.Pages.PricingModel
@{
    ViewData["Title"] = "Pricing";
}

<div class="pricing-page">

    <h1 class="section-title">Pricing</h1>

    <div class="pricing-grid">

        <div class="pricing-card">
            <h2>Free</h2>
            <div class="price">$0</div>

            <ul>
                <li>1 Full Analysis</li>
                <li>Repair Estimator</li>
                <li>Buy/Sell/Trade Analysis</li>
                <li>Resource Links</li>
            </ul>

            <a class="btn-primary" href="/Register">Get Started</a>
        </div>

        <div class="pricing-card featured">
            <h2>Unlimited</h2>
            <div class="price">$9.99/mo</div>

            <ul>
                <li>Unlimited Analyses</li>
                <li>Repair Estimator</li>
                <li>Buy/Sell/Trade Analysis</li>
                <li>Upgrade Analysis</li>
                <li>Priority Features</li>
            </ul>

            <button class="btn-primary">
                Subscribe
            </button>
        </div>

    </div>

</div>